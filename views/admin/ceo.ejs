<%- include('../partials/admin_header') %> <!-- Gunakan header yg sama untuk admin -->
<div class="p-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-blue-400 tracking-tighter">CENTRAL EXPLOIT OFFICER (CEO)</h1>
        <div class="text-xs p-2 border border-blue-500 rounded">SYSTEM: ONLINE</div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Add API Key -->
        <div class="cyber-card p-6 rounded-xl border border-blue-900 bg-slate-900/50">
            <h2 class="mb-4 text-xl">Inject API Key (OpenRouter)</h2>
            <form action="/admin/api/add" method="POST" class="space-y-4">
                <input type="text" name="apiKey" placeholder="sk-or-v1-..." class="w-full bg-slate-800 p-3 rounded border border-blue-500 outline-none">
                <button class="bg-blue-600 w-full py-2 rounded hover:bg-blue-400 transition">ADD KEY</button>
            </form>
        </div>

        <!-- List API Keys -->
        <div class="cyber-card p-6 rounded-xl border border-blue-900 bg-slate-900/50">
            <h2 class="mb-4 text-xl">Active Key Infrastructure</h2>
            <div class="space-y-2 max-height-[300px] overflow-y-auto">
                <!-- Example Loop -->
                <div class="flex justify-between p-3 bg-slate-800 rounded border-l-4 border-green-500">
                    <span class="text-xs truncate mr-4">sk-or-v1-adc73...477a70</span>
                    <button class="text-red-500 hover:text-red-300">DELETE</button>
                </div>
            </div>
        </div>
    </div>
</div>
